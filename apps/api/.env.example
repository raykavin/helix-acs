# Helix ACS – REST API server
# Copy to .env and adjust values before running

APP_NAME=helix-api
LOG_LEVEL=info

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=helixacs

# Redis
REDIS_URI=redis://localhost:6379

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# HTTP API
API_PORT=8080

# ACS credentials (used for API auth guard matching CWMP server)
ACS_USERNAME=admin
ACS_PASSWORD=change-me

# Config file path
CONFIG_PATH=./configs/config.yml
