# Helix ACS – CWMP/TR-069 server
# Copy to .env and adjust values before running

APP_NAME=helix-cwmp
LOG_LEVEL=info

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=helixacs

# Redis
REDIS_URI=redis://localhost:6379

# CWMP/ACS
ACS_PORT=7547
ACS_USERNAME=admin
ACS_PASSWORD=change-me
ACS_URL=http://localhost:7547/acs
ACS_INFORM_INTERVAL=3600s
ACS_SCHEMAS_DIR=./schemas

# Config file path
CONFIG_PATH=./configs/config.yml
